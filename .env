# Life Protocol — kliensoldali konfiguráció (Vite: VITE_ prefix kötelező)
# Ez a fájl verziókövetett (a benne lévő értékek a klienskódba kerülnek, nem titkok).
# Lokális felülíráshoz/titkokhoz használj .env.local fájlt (az gitignore-olt).

# --- Esemény ---
VITE_EVENT_DATE=2026-10-15T09:00:00+02:00

# --- Jegyárak (Ft, egész szám, ezres elválasztó nélkül) ---
VITE_PRICE_EARLY_BIRD=34900
VITE_PRICE_NORMAL=49900
VITE_PRICE_VIP=89900

# --- Analytics (hagyd üresen, ha még nincs — akkor nem töltődik be semmi) ---
VITE_GTM_ID=
VITE_META_PIXEL_ID=
