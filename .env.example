# Másold .env-be, és töltsd ki a valós értékekkel.
# Minden VITE_ változó a kliensoldali bundle-be kerül (nem titkos adatoknak való).

# Esemény dátuma (ISO 8601, időzónával) — a visszaszámláló ezt használja
VITE_EVENT_DATE=2026-10-15T09:00:00+02:00

# Helyszín (város, toldalék nélkül) — pl. Budapest
VITE_EVENT_LOCATION=Budapest

# Helyszín neve (terem/központ) és térkép-link (pl. Google Maps megosztási link)
VITE_EVENT_VENUE=Lurdy Conference and Event Center
VITE_EVENT_MAP_URL=https://www.google.com/maps/search/?api=1&query=Lurdy+Conference+and+Event+Center+Budapest

# Jegyárak forintban (egész szám)
VITE_PRICE_EARLY_BIRD=34900
VITE_PRICE_NORMAL=49900
VITE_PRICE_VIP=89900

# Early Bird jegy határideje (ISO 8601, időzónával)
VITE_EARLY_BIRD_DEADLINE=2026-09-15T23:59:59+02:00

# Google Tag Manager konténer azonosító (pl. GTM-XXXXXXX)
VITE_GTM_ID=

# Meta (Facebook) Pixel azonosító (pl. 1234567890)
VITE_META_PIXEL_ID=
